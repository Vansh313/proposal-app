# ── COLORS ──────────────────────────────────────────────────────────────────
GOLD       = colors.HexColor("#C9A96E")
DARK       = colors.HexColor("#1A0A06")
BODY_COLOR = colors.HexColor("#2C2C2C")
MID_COLOR  = colors.HexColor("#6B6055")
LIGHT_BG   = colors.HexColor("#FAF7F2")
ALT_BG     = colors.HexColor("#F0E8D8")
RULE_LIGHT = colors.HexColor("#E8E0D0")

def build_styles():
    return {
        "studio": ParagraphStyle("studio", fontName="Times-Roman", fontSize=8,
            textColor=GOLD, alignment=TA_CENTER, spaceAfter=6, leading=12),
        "title": ParagraphStyle("title", fontName="Times-Roman", fontSize=22,
            textColor=DARK, alignment=TA_CENTER, spaceAfter=6, leading=28),
        "meta": ParagraphStyle("meta", fontName="Helvetica", fontSize=9,
            textColor=MID_COLOR, alignment=TA_CENTER, spaceAfter=0, leading=14),
        "sec_num": ParagraphStyle("sec_num", fontName="Helvetica-Bold", fontSize=8,
            textColor=GOLD, alignment=TA_LEFT, spaceAfter=0, leading=12),
        "sec_title": ParagraphStyle("sec_title", fontName="Helvetica", fontSize=8,
            textColor=MID_COLOR, alignment=TA_LEFT, spaceAfter=4, leading=12),
        "room": ParagraphStyle("room", fontName="Times-Bold", fontSize=11,
            textColor=DARK, alignment=TA_LEFT, spaceAfter=4, leading=16),
        "body": ParagraphStyle("body", fontName="Helvetica", fontSize=10,
            textColor=BODY_COLOR, alignment=TA_JUSTIFY, spaceAfter=10, leading=16),
        "bold_key": ParagraphStyle("bold_key", fontName="Helvetica-Bold", fontSize=10,
            textColor=DARK, alignment=TA_LEFT, spaceAfter=6, leading=15),
        "bullet": ParagraphStyle("bullet", fontName="Helvetica", fontSize=10,
            textColor=BODY_COLOR, alignment=TA_LEFT, spaceAfter=6, leading=15,
            leftIndent=14),
        "sig": ParagraphStyle("sig", fontName="Times-Italic", fontSize=11.5,
            textColor=DARK, alignment=TA_CENTER, spaceAfter=8, leading=18),
        "footer": ParagraphStyle("footer", fontName="Helvetica", fontSize=8,
            textColor=MID_COLOR, alignment=TA_CENTER, leading=12),
        "budget_note": ParagraphStyle("budget_note", fontName="Helvetica-Oblique", fontSize=10,
            textColor=MID_COLOR, alignment=TA_LEFT, spaceAfter=10, leading=15),
    }

def gold_rule(width="100%", before=0, after=10):
    return HRFlowable(width=width, thickness=0.8, color=GOLD,
                      spaceBefore=before, spaceAfter=after)

def hair_rule(after=8):
    return HRFlowable(width="100%", thickness=0.4, color=RULE_LIGHT,
                      spaceBefore=2, spaceAfter=after)

def section_header(num, title, styles):
    return [
        Spacer(1, 14),
        Paragraph(f'{num}  —  {title.upper()}', ParagraphStyle(
            "sh", fontName="Helvetica", fontSize=8, textColor=MID_COLOR,
            leading=12, spaceAfter=4)),
        gold_rule(after=12),
    ]

def parse_proposal(text):
    """Parse the proposal text into structured sections."""
    sections = {}
    current = None
    current_lines = []

    for line in text.split('\n'):
        stripped = line.strip()
        if not stripped:
            if current:
                current_lines.append('')
            continue

        # Detect section headers
        import re
        match = re.match(r'^(\d+)\.\s+(.*?)(?:\s*[-–—]+\s*)?$', stripped)
        if match and len(match.group(2)) < 60:
            if current:
                sections[current] = '\n'.join(current_lines).strip()
            current = match.group(2).strip().upper()
            current_lines = []
        elif stripped.startswith('INTERIOR DESIGN PROPOSAL') or stripped.startswith('Prepared for'):
            if 'HEADER' not in sections:
                sections['HEADER'] = stripped
            else:
                sections['HEADER'] += '\n' + stripped
        elif current:
            current_lines.append(stripped)

    if current:
        sections[current] = '\n'.join(current_lines).strip()

    return sections

def build_pdf(proposal_text, designer, client, city):
    """Build a premium PDF from proposal text."""
    buf = io.BytesIO()
    W, H = A4
    margin = 22 * mm

    doc = SimpleDocTemplate(buf, pagesize=A4,
        leftMargin=margin, rightMargin=margin,
        topMargin=margin, bottomMargin=margin)

    styles = build_styles()
    story = []
    date_str = datetime.now().strftime("%B %Y")

    # ── ELEGANT HEADER ────────────────────────────────────────────────────────
    story.append(Spacer(1, 8*mm))
    story.append(Paragraph(designer.upper(), styles["studio"]))
    story.append(Spacer(1, 4))
    story.append(Paragraph("Interior Design Proposal", styles["title"]))
    story.append(gold_rule(before=4, after=6))
    story.append(Paragraph(
        f'Prepared for  <b>{client}</b>   ·   {designer}   ·   {city}   ·   {date_str}',
        styles["meta"]))
    story.append(gold_rule(before=6, after=0))
    story.append(Spacer(1, 16*mm))

    # ── PARSE AND BUILD SECTIONS ───────────────────────────────────────────────
    sections = parse_proposal(proposal_text)

    section_map = {
        "DESIGN VISION": "01",
        "ROOM-BY-ROOM DIRECTION": "02",
        "SERVICES AND DELIVERABLES": "03",
        "SERVICES & DELIVERABLES": "03",
        "MATERIAL AND FINISH PALETTE": "04",
        "MATERIAL & FINISH PALETTE": "04",
        "INVESTMENT BREAKDOWN": "05",
        "PROJECT TIMELINE": "06",
        "NEXT STEPS": "07",
        "WHY THIS APPROACH WORKS": "08",
        "SIGNATURE MOMENT": "09",
    }

    for sec_title, num in section_map.items():
        content = sections.get(sec_title, "")
        if not content:
            continue

        story += section_header(num, sec_title.replace(" AND ", " & "), styles)

        if sec_title == "SIGNATURE MOMENT":
            story.append(Spacer(1, 4))
            story.append(Paragraph(content, styles["sig"]))
            story.append(Spacer(1, 4))

        elif sec_title == "INVESTMENT BREAKDOWN":
            # Budget note
            lines = content.split('\n')
            table_lines = []
            for line in lines:
                if 'recommend positioning' in line.lower():
                    story.append(Paragraph(line, styles["budget_note"]))
                elif line.strip() and ':' in line:
                    parts = line.rsplit(':', 1)
                    if len(parts) == 2:
                        table_lines.append([parts[0].strip(), parts[1].strip()])

            if table_lines:
                col_w = [(W - 2*margin) * 0.68, (W - 2*margin) * 0.32]
                tdata = []
                for i, (lbl, amt) in enumerate(table_lines):
                    is_total = 'TOTAL' in lbl.upper()
                    tdata.append([
                        Paragraph(lbl, ParagraphStyle("tc", fontName="Helvetica-Bold" if is_total else "Helvetica",
                            fontSize=10, textColor=BODY_COLOR, leading=14)),
                        Paragraph(amt, ParagraphStyle("ta", fontName="Helvetica-Bold" if is_total else "Helvetica",
                            fontSize=10, textColor=BODY_COLOR, leading=14, alignment=TA_CENTER))
                    ])
                t = Table(tdata, colWidths=col_w)
                row_colors = []
                for i in range(len(tdata)):
                    is_total = 'TOTAL' in table_lines[i][0].upper()
                    bg = ALT_BG if is_total else (LIGHT_BG if i % 2 == 0 else colors.white)
                    row_colors.append(('BACKGROUND', (0,i), (-1,i), bg))
                t.setStyle(TableStyle([
                    ('BOX', (0,0), (-1,-1), 0, colors.white),
                    ('INNERGRID', (0,0), (-1,-1), 0, colors.white),
                    ('TOPPADDING', (0,0), (-1,-1), 7),
                    ('BOTTOMPADDING', (0,0), (-1,-1), 7),
                    ('LEFTPADDING', (0,0), (0,-1), 10),
                    ('RIGHTPADDING', (1,0), (1,-1), 10),
                    ('LINEABOVE', (0,len(tdata)-1), (-1,len(tdata)-1), 0.6, GOLD),
                ] + row_colors))
                story.append(t)
                story.append(Spacer(1, 8))

        elif sec_title in ("SERVICES AND DELIVERABLES", "SERVICES & DELIVERABLES",
                           "WHY THIS APPROACH WORKS"):
            for line in content.split('\n'):
                line = line.strip().lstrip('-•—').strip()
                if line:
                    story.append(Paragraph(f"— {line}", styles["bullet"]))

        elif sec_title in ("MATERIAL AND FINISH PALETTE", "MATERIAL & FINISH PALETTE"):
            lines = content.split('\n')
            for line in lines:
                line = line.strip()
                if not line:
                    continue
                if line.isupper() and len(line) < 40:
                    story.append(Spacer(1, 4))
                    story.append(Paragraph(line, styles["room"]))
                    story.append(hair_rule())
                elif ':' in line:
                    parts = line.split(':', 1)
                    story.append(Paragraph(
                        f'<b>{parts[0].strip()}:</b>  {parts[1].strip()}',
                        styles["bullet"]))
                else:
                    story.append(Paragraph(f"— {line.lstrip('-•—').strip()}", styles["bullet"]))

        elif sec_title == "PROJECT TIMELINE":
            lines = content.split('\n')
            i = 0
            while i < len(lines):
                line = lines[i].strip()
                if not line:
                    i += 1
                    continue
                # Phase header
                if line.lower().startswith('phase'):
                    parts = line.split(':', 1) if ':' in line else [line, '']
                    phase_name = parts[0].strip()
                    dates = parts[1].strip() if len(parts) > 1 else ''
                    # Check next line for dates
                    if not dates and i+1 < len(lines):
                        next_line = lines[i+1].strip()
                        if any(month in next_line for month in ['January','February','March','April','May','June','July','August','September','October','November','December']):
                            dates = next_line
                            i += 1
                    story.append(Spacer(1, 4))
                    story.append(Paragraph(
                        f'<b>{phase_name}</b>   <font color="#C9A96E" size="9">{dates}</font>',
                        styles["bold_key"]))
                elif line:
                    story.append(Paragraph(line, styles["body"]))
                i += 1

        elif sec_title == "NEXT STEPS":
            lines = content.split('\n')
            step_num = 1
            for line in lines:
                line = line.strip()
                if not line:
                    continue
                line = line.lstrip('0123456789.-).').strip()
                if line:
                    story.append(Paragraph(f'<b>{step_num}.</b>  {line}', styles["body"]))
                    step_num += 1

        else:
            # Body sections
            paragraphs = content.split('\n\n') if '\n\n' in content else content.split('\n')
            for para in paragraphs:
                para = para.strip()
                if not para:
                    continue
                if para.isupper() and len(para) < 40:
                    story.append(Paragraph(para, styles["room"]))
                    story.append(hair_rule())
                else:
                    story.append(Paragraph(para, styles["body"]))

    # ── FOOTER ────────────────────────────────────────────────────────────────
    story.append(Spacer(1, 12*mm))
    story.append(gold_rule(before=2, after=6))
    story.append(Paragraph(
        f'{designer}   ·   {city}   ·   {date_str}   ·   Confidential',
        styles["footer"]))

    doc.build(story)
    buf.seek(0)
    return buf.read()





def send_email_with_pdf(to_email, designer, client, pdf_bytes):
    """Send email with PDF attachment via Resend."""
    api_key = os.environ.get('RESEND_API_KEY', '')
    from_email = os.environ.get('FROM_EMAIL', 'onboarding@resend.dev')

    if not api_key:
        return False, "No Resend API key"

    resend.api_key = api_key
    encoded = base64.b64encode(pdf_bytes).decode()
    filename = f"Proposal_{client.replace(' ', '_')}.pdf"

    try:
        response = resend.Emails.send({
            "from": f"{designer} <{from_email}>",
            "to": [to_email],
            "subject": "Your Interior Design Proposal is Ready ✨",
            "html": f"""
            <div style="font-family: Georgia, serif; max-width: 600px; margin: 0 auto; padding: 40px 20px; color: #2C2C2C;">
                <p style="color: #C9A96E; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 4px;">{designer}</p>
                <h2 style="font-size: 22px; font-weight: normal; color: #1A0A06; margin: 0 0 20px 0;">Your proposal is ready.</h2>
                <p style="font-size: 15px; line-height: 1.7; color: #6B6055;">Dear {client},</p>
                <p style="font-size: 15px; line-height: 1.7; color: #6B6055;">
                    Please find your interior design proposal attached. It has been crafted specifically for your project and outlines our complete vision, timeline, and investment structure.
                </p>
                <p style="font-size: 15px; line-height: 1.7; color: #1A0A06; margin-top: 30px;">Warmly,<br><b>{designer}</b></p>
                <hr style="border: none; border-top: 1px solid #E8E0D0; margin: 30px 0 20px 0;">
                <p style="font-size: 11px; color: #B0A090;">This proposal is confidential and prepared exclusively for {client}.</p>
            </div>
            """,
            "attachments": [{
                "filename": filename,
                "content": encoded,
            }]
        })
        return True, f"Sent: {response}"
    except Exception as e:
        return False, str(e)


@app.route('/generate', methods=['POST'])
def generate():
    data = request.json or {}

    proposal_text = data.get('proposal_text', '')
    designer = data.get('designer', 'Studio')
    client = data.get('client', 'Client')
    city = data.get('city', '')
    to_email = data.get('recipient_email', '')

    if not proposal_text:
        return jsonify({"error": "proposal_text is required"}), 400

    # Generate PDF
    try:
        pdf_bytes = build_pdf(proposal_text, designer, client, city)
    except Exception as e:
        return jsonify({"error": f"PDF generation failed: {str(e)}"}), 500

    # Send email
    if to_email:
        success, msg = send_email_with_pdf(to_email, designer, client, pdf_bytes)
        if success:
            return jsonify({"success": True, "message": f"PDF sent to {to_email}"}), 200
        else:
            # Return PDF as base64 if email fails
            return jsonify({
                "success": False,
                "message": msg,
                "pdf_base64": base64.b64encode(pdf_bytes).decode()
            }), 200
    else:
        return jsonify({
            "success": True,
            "pdf_base64": base64.b64encode(pdf_bytes).decode()
        }), 200


